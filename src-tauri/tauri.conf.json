{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chulada-pos",
  "version": "0.1.0",
  "identifier": "com.aragelsoft.chuladapos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chulada POS",
        "width": 800,
        "height": 600,
        "maximized": true,
        "resizable": true,
        "minWidth": 320,
        "minHeight": 600,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aragel-soft/chulada-pos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1RjZDMTMwOTNBMjNGRTgKUldUb1A2S1RNTUgyUlZHeHNjUU1NRS9YUHV1NEFPb1ZxOUNXc0dSYzBYeHU2U2drNWJxUmZIaEcK"
    }
  }
}